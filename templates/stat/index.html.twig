{% extends '_layouts/in_app.html.twig' %}

{% block title %}Fiche Athlète - PitchSport{% endblock %}

{% block content %}
<div class="page active" id="page-athlete">
<a href="{{ path('home') }}" class="athlete-back">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
  Retour à l'effectif
</a>

<div class="athlete-header" id="athlete-header"></div>

<div class="grid-4 athlete-metrics-grid" id="athlete-metrics"></div>

<div class="card athlete-history-card">
  <div class="section-header athlete-history-header">
    <div class="section-title">Historique de charge</div>
    {% set currentTab = app.request.query.get('tab', 'acwr') %}
    <div class="tabs" id="athlete-chart-tabs">
      <a href="?tab=acwr" class="tab {% if currentTab == 'acwr' %}active{% endif %}">ACWR</a>
      <a href="?tab=vmax" class="tab {% if currentTab == 'vmax' %}active{% endif %}">Vmax Drop</a>
      <a href="?tab=distance" class="tab {% if currentTab == 'distance' %}active{% endif %}">Distance</a>
      <a href="?tab=foster" class="tab {% if currentTab == 'foster' %}active{% endif %}">Monotonie</a>
    </div>
  </div>
  <div class="athlete-chart-wrapper">
    {% import "stat/_chart_macro.html.twig" as charts %}

    {% if currentTab == 'acwr' %}
        {# Chart ACWR #}
        {{ charts.bar_chart(acwrHistory, 'acwr', 2.0) }}
    {% elseif currentTab == 'vmax' %}
        {# Chart Vmax Drop (en %) #}
        {{ charts.variation_chart(vmaxDropHistory, 'vmax', 20.0) }}
    {% elseif currentTab == 'distance' %}
        {# Chart Distance #}
        {{ charts.bar_chart(distanceHistory, 'distance', 15000) }}
    {% elseif currentTab == 'foster' %}
        {# Chart Monotonie de Foster #}
        {{ charts.bar_chart(fosterHistory, 'foster', 3.0) }}
    {% endif %}
  </div>
</div>

<div class="card">
  <div class="section-title athlete-sessions-title">Dernières séances</div>
  <div id="athlete-sessions" class="grid-3" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
    
    {# ACWR Card #}
    {% set acwrColor = '#10b981' %}
    {% if currentAcwrLevel == 1 %}{% set acwrColor = '#f59e0b' %}{% endif %}
    {% if currentAcwrLevel == 2 %}{% set acwrColor = '#ef4444' %}{% endif %}
    <div class="stat-box" style="padding: 16px; border-radius: 8px; text-align: center; border: 1px solid #e2e8f0;">
        <div style="font-size: 12px; color: #64748b; margin-bottom: 8px; font-weight: 500;">ACWR</div>
        <div style="font-size: 24px; font-weight: bold; color: {{ acwrColor }};">
            {{ currentAcwr !== null ? currentAcwr : '-' }}
        </div>
    </div>

    {# VMAX Drop Card #}
    {% set vmaxColor = '#10b981' %}
    {% if currentVmaxLevel == 1 %}{% set vmaxColor = '#f59e0b' %}{% endif %}
    {% if currentVmaxLevel == 2 %}{% set vmaxColor = '#ef4444' %}{% endif %}
    <div class="stat-box" style="padding: 16px; border-radius: 8px; text-align: center; border: 1px solid #e2e8f0;">
        <div style="font-size: 12px; color: #64748b; margin-bottom: 8px; font-weight: 500;">VMAX Variation</div>
        <div style="font-size: 24px; font-weight: bold; color: {{ vmaxColor }};">
            {{ currentVmaxDrop !== null ? currentVmaxDrop ~ '%' : '-' }}
        </div>
    </div>

    {# Foster Card #}
    {% set fosterColor = '#10b981' %}
    {% if currentFosterLevel == 1 %}{% set fosterColor = '#f59e0b' %}{% endif %}
    {% if currentFosterLevel == 2 %}{% set fosterColor = '#ef4444' %}{% endif %}
    <div class="stat-box" style="padding: 16px; border-radius: 8px; text-align: center; border: 1px solid #e2e8f0;">
        <div style="font-size: 12px; color: #64748b; margin-bottom: 8px; font-weight: 500;">Monotonie</div>
        <div style="font-size: 24px; font-weight: bold; color: {{ fosterColor }};">
            {{ currentFoster !== null ? currentFoster : '-' }}
        </div>
    </div>

  </div>
</div>
</div>
{% endblock %}
