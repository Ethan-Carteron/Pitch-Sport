{% extends '_layouts/in_app.html.twig' %}

{% block title %}Fiche Athlète - PitchSport{% endblock %}

{% block content %}
<div class="page active" id="page-athlete">
<a href="{{ path('home') }}" class="athlete-back">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <line x1="19" y1="12" x2="5" y2="12"></line>
      <polyline points="12 19 5 12 12 5"></polyline>
  </svg>
  Retour à l'effectif
</a>

<div class="athlete-header" id="athlete-header"></div>

<div class="grid-4 athlete-metrics-grid" id="athlete-metrics"></div>

<div class="card athlete-history-card">
  <div class="section-header athlete-history-header">
    <div class="section-title">Historique de charge</div>
    {% set currentTab = app.request.query.get('tab', 'acwr') %}
    <div class="tabs" id="athlete-chart-tabs">
      <a href="?tab=acwr" class="tab {% if currentTab == 'acwr' %}active{% endif %}">ACWR</a>
      <a href="?tab=vmax" class="tab {% if currentTab == 'vmax' %}active{% endif %}">Vmax Drop</a>
      <a href="?tab=distance" class="tab {% if currentTab == 'distance' %}active{% endif %}">Distance</a>
      <a href="?tab=foster" class="tab {% if currentTab == 'foster' %}active{% endif %}">Monotonie</a>
    </div>
  </div>
  <div class="athlete-chart-wrapper">
    {% import "stat/_chart_macro.html.twig" as charts %}

    {% if currentTab == 'acwr' %}
        {# Chart ACWR #}
        {{ charts.bar_chart(acwrHistory, 'acwr') }}
    {% elseif currentTab == 'vmax' %}
        {# Chart Vmax Drop (en %) #}
        {{ charts.variation_chart(vmaxDropHistory, 'vmax') }}
    {% elseif currentTab == 'distance' %}
        {# Chart Distance #}
        {{ charts.bar_chart(distanceHistory, 'distance') }}
    {% elseif currentTab == 'foster' %}
        {# Chart Monotonie de Foster #}
        {{ charts.bar_chart(fosterHistory, 'foster') }}
    {% endif %}
  </div>
</div>

<div class="card">
  <div class="section-title athlete-sessions-title">Dernières séances</div>
  <div id="athlete-sessions" class="grid-3">

    {# ACWR Card #}
    <div class="stat-box">
        <div class="stat-box-title">ACWR</div>
        <div class="stat-box-value status-{{ currentAcwrLevel }}">
            {{ currentAcwr !== null ? currentAcwr : '-' }}
        </div>
    </div>

    {# VMAX Drop Card #}
    <div class="stat-box">
        <div class="stat-box-title">VMAX Variation</div>
        <div class="stat-box-value status-{{ currentVmaxLevel }}">
            {{ currentVmaxDrop !== null ? currentVmaxDrop ~ '%' : '-' }}
        </div>
    </div>

    {# Foster Card #}
    <div class="stat-box">
        <div class="stat-box-title">Monotonie</div>
        <div class="stat-box-value status-{{ currentFosterLevel }}">
            {{ currentFoster !== null ? currentFoster : '-' }}
        </div>
    </div>

  </div>
</div>

{% if advices is not empty %}
<div class="card">
  <div class="section-title">Conseils</div>
  <div class="advices-list">
    {% for advice in advices %}
      {% set adviceColor = advice.level == 2 ? 'rouge' : (advice.level == 1 ? 'orange' : 'vert') %}
      <div class="advice-row {{ adviceColor }}">
        <span class="advice-metric">{{ advice.metric|upper }}</span>
        <span class="advice-message">{{ advice.message }}</span>
      </div>
    {% endfor %}
  </div>
</div>
{% endif %}

</div>
{% endblock %}
