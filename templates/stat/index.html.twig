{% extends '_layouts/in_app.html.twig' %}

{% block title %}Fiche Athlète - PitchSport{% endblock %}

{% block content %}
<div class="page active" id="page-athlete">
<div class="athlete-back">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
  Retour à l'effectif
</div>

<div class="athlete-header" id="athlete-header"></div>

<div class="grid-4 athlete-metrics-grid" id="athlete-metrics"></div>

<div class="card athlete-history-card">
  <div class="section-header athlete-history-header">
    <div class="section-title">Historique de charge</div>
    <div class="tabs" id="athlete-chart-tabs">
      <div class="tab active">ACWR</div>
      <div class="tab">Distance</div>
      <div class="tab">Vmax</div>
      <div class="tab">Accél / Décél</div>
    </div>
  </div>
  <div class="athlete-chart-wrapper">
    <style>
      {% for key, item in acwrHistory %}
          .acwr-bar-{{ key }} { height: {{ (item.acwr / 2.0) * 100 }}%; }
      {% endfor %}
    </style>
    <div class="css-graph-container">
        {% for key, item in acwrHistory %}
            {% set barClass = 'bg-vert' %}
            {% if item.level == 1 %}{% set barClass = 'bg-orange' %}{% endif %}
            {% if item.level == 2 %}{% set barClass = 'bg-rouge' %}{% endif %}
            
            <div class="css-graph-col">
                <div class="css-graph-bar {{ barClass }} acwr-bar-{{ key }}">
                    <span class="css-graph-value">{{ item.acwr }}</span>
                </div>
                <div class="css-graph-label">{{ item.date }}</div>
            </div>
        {% else %}
            <div class="css-graph-empty">Pas assez de données pour afficher l'historique ACWR.</div>
        {% endfor %}
    </div>
  </div>
</div>

<div class="card">
  <div class="section-title athlete-sessions-title">Dernières séances</div>
  <div id="athlete-sessions"></div>
</div>
</div>
{% endblock %}
