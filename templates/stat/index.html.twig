{% extends '_layouts/in_app.html.twig' %}

{% block title %}Fiche Athlète - PitchSport{% endblock %}

{% block content %}
<div class="page active" id="page-athlete">
<div class="athlete-back">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
  Retour à l'effectif
</div>

<div class="athlete-header" id="athlete-header"></div>

<div class="grid-4 athlete-metrics-grid" id="athlete-metrics"></div>

<div class="card athlete-history-card">
  <div class="section-header athlete-history-header">
    <div class="section-title">Historique de charge</div>
    {% set currentTab = app.request.query.get('tab', 'acwr') %}
    <div class="tabs" id="athlete-chart-tabs">
      <a href="?tab=acwr" class="tab {% if currentTab == 'acwr' %}active{% endif %}" style="text-decoration: none; color: inherit;">ACWR</a>
      <a href="?tab=vmax" class="tab {% if currentTab == 'vmax' %}active{% endif %}" style="text-decoration: none; color: inherit;">Vmax Drop</a>
      <a href="?tab=distance" class="tab {% if currentTab == 'distance' %}active{% endif %}" style="text-decoration: none; color: inherit;">Distance</a>
      <a href="?tab=foster" class="tab {% if currentTab == 'foster' %}active{% endif %}" style="text-decoration: none; color: inherit;">Monotonie</a>
    </div>
  </div>
  <div class="athlete-chart-wrapper">
    {% import "stat/_chart_macro.html.twig" as charts %}

    {% if currentTab == 'acwr' %}
        {# Chart ACWR #}
        {{ charts.bar_chart(acwrHistory, 'acwr', 2.0) }}
    {% elseif currentTab == 'vmax' %}
        {# Chart Vmax Drop (en %) #}
        {{ charts.bar_chart(vmaxDropHistory, 'vmax', 20.0) }}
    {% elseif currentTab == 'foster' %}
        {# Chart Monotonie de Foster #}
        {{ charts.bar_chart(fosterHistory, 'foster', 3.0) }}
    {% endif %}
  </div>
</div>

<div class="card">
  <div class="section-title athlete-sessions-title">Dernières séances</div>
  <div id="athlete-sessions"></div>
</div>
</div>
{% endblock %}
