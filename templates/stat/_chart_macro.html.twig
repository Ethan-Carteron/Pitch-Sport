{% macro bar_chart(data, idPrefix) %}
    {% set computedMax = 0 %}
    {% for item in data %}
        {% if item.value > computedMax %}
            {% set computedMax = item.value %}
        {% endif %}
    {% endfor %}
    {% set maxValue = computedMax > 0 ? computedMax * 1.1 : 1 %}

    <style>
      {% for key, item in data %}
          .{{ idPrefix }}-bar-{{ key }} { height: {{ (item.value / maxValue) * 100 }}%; }
      {% endfor %}
    </style>
    <div class="css-graph-container" id="{{ idPrefix }}-chart">
        {% for key, item in data %}
            {% set barClass = 'bg-vert' %}
            {% if item.level == 1 %}{% set barClass = 'bg-orange' %}{% endif %}
            {% if item.level == 2 %}{% set barClass = 'bg-rouge' %}{% endif %}
            
            <div class="css-graph-col">
                <div class="css-graph-bar {{ barClass }} {{ idPrefix }}-bar-{{ key }}">
                    <span class="css-graph-value">{{ item.value }}</span>
                </div>
                <div class="css-graph-label">{{ item.date }}</div>
            </div>
        {% else %}
            <div class="css-graph-empty">Pas assez de données pour afficher l'historique {{ idPrefix|upper }}.</div>
        {% endfor %}
    </div>
{% endmacro %}

{% macro variation_chart(data, idPrefix) %}
    {% set computedMax = 0 %}
    {% for item in data %}
        {% if item.value|abs > computedMax %}
            {% set computedMax = item.value|abs %}
        {% endif %}
    {% endfor %}
    {% set maxValue = computedMax > 0 ? computedMax * 1.1 : 1 %}

    <style>
      {% for key, item in data %}
          {% set heightPct = (item.value|abs / maxValue) * 50 %}
          .{{ idPrefix }}-bar-{{ key }} { height: {{ heightPct > 50 ? 50 : heightPct }}%; }
      {% endfor %}
    </style>
    <div class="css-graph-variation-container" id="{{ idPrefix }}-chart">
        {% for key, item in data %}
            {% set barClass = 'bg-vert' %}
            {% if item.level == 1 %}{% set barClass = 'bg-orange' %}{% endif %}
            {% if item.level == 2 %}{% set barClass = 'bg-rouge' %}{% endif %}
            
            <div class="css-graph-variation-col">
                <div class="css-graph-variation-bar-wrapper">
                    {% if item.value >= 0 %}
                        <div class="css-graph-variation-bar positive {{ barClass }} {{ idPrefix }}-bar-{{ key }}">
                            <span class="css-graph-value top">{{ item.value|round(1) }}</span>
                        </div>
                    {% else %}
                        <div class="css-graph-variation-bar negative {{ barClass }} {{ idPrefix }}-bar-{{ key }}">
                            <span class="css-graph-value bottom">{{ item.value|round(1) }}</span>
                        </div>
                    {% endif %}
                </div>
                <div class="css-graph-label">{{ item.date }}</div>
            </div>
        {% else %}
            <div class="css-graph-empty">Pas assez de données pour afficher l'historique {{ idPrefix|upper }}.</div>
        {% endfor %}
    </div>
{% endmacro %}
