{% extends '_layouts/in_app.html.twig' %}

{% block title %}Accueil ! - PitchSport{% endblock %}

{% block content %}
    {% set currentFilter = app.request.query.get('filter', 'all') %}
    <div class="page active" id="page-overview">
        <div class="page-header">
            <h1 class="page-title">Bonjour, Ethan.</h1>
            <p class="page-subtitle">Voici l'état de votre effectif ce matin.</p>
        </div>

        {% if redCount > 0 %}
            <div class="alert-banner rouge" id="alert-rouge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="8" x2="12" y2="12"></line>
                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
                <strong>{{ redCount }} athlète{{ redCount > 1 ? 's' : '' }} en zone de surcharge.</strong>&nbsp;Vérifiez la charge avant l'entraînement.
            </div>
        {% endif %}

        <!-- KPIs -->
        <div class="grid-4 overview-metrics">
            <a href="{{ path('home', {filter: currentFilter == 'all' ? 'all' : 'all'}) }}" class="metric-card {% if currentFilter == 'all' %}active{% endif %}" data-filter="all" id="kpi-all">
                <div class="metric-label">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg>
                    Effectif actif
                </div>
                <div class="metric-value neutral">{{ activePlayersCount }}</div>
                <div class="metric-sub">athlètes suivis</div>
            </a>
            <a href="{{ path('home', {filter: currentFilter == 'rouge' ? 'all' : 'rouge'}) }}" class="metric-card {% if currentFilter == 'rouge' %}active{% endif %}" data-filter="rouge" id="kpi-rouge">
                <div class="metric-label">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    Zone rouge
                </div>
                <div class="metric-value rouge">{{ redCount }}</div>
                <div class="metric-sub">surcharge détectée</div>
            </a>
            <a href="{{ path('home', {filter: currentFilter == 'orange' ? 'all' : 'orange'}) }}" class="metric-card {% if currentFilter == 'orange' %}active{% endif %}" data-filter="orange" id="kpi-orange">
                <div class="metric-label">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path
                            d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                    </svg>
                    Zone orange
                </div>
                <div class="metric-value orange">{{ orangeCount }}</div>
                <div class="metric-sub">à surveiller</div>
            </a>
            <a href="{{ path('home', {filter: currentFilter == 'vert' ? 'all' : 'vert'}) }}" class="metric-card {% if currentFilter == 'vert' %}active{% endif %}" data-filter="vert" id="kpi-vert">
                <div class="metric-label">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Zone verte
                </div>
                <div class="metric-value vert">{{ greenCount }}</div>
                <div class="metric-sub">charge optimale</div>
            </a>
        </div>

        <!-- Filtre + liste -->
        <div class="section-header">
            <div class="section-title">Effectif complet</div>
            <div class="tabs" id="filter-tabs">
                <a href="{{ path('home', {filter: 'all'}) }}" class="tab {% if currentFilter == 'all' %}active{% endif %}">Tous</a>
                <a href="{{ path('home', {filter: 'rouge'}) }}" class="tab {% if currentFilter == 'rouge' %}active{% endif %}">Rouge</a>
                <a href="{{ path('home', {filter: 'orange'}) }}" class="tab {% if currentFilter == 'orange' %}active{% endif %}">Orange</a>
                <a href="{{ path('home', {filter: 'vert'}) }}" class="tab {% if currentFilter == 'vert' %}active{% endif %}">Vert</a>
            </div>
        </div>

        <div class="athletes-list" id="athletes-list">
            {% set filteredPlayers = [] %}
            {% for player in activePlayers %}
                {% set colorClass = player.score > 60 ? 'rouge' : (player.score > 30 ? 'orange' : 'vert') %}
                {% if currentFilter == 'all' or colorClass == currentFilter %}
                    {% set filteredPlayers = filteredPlayers|merge([{player: player, colorClass: colorClass}]) %}
                {% endif %}
            {% endfor %}

            {% for item in filteredPlayers %}
                <a href="{{ path('app_stat', {uid: item.player.uid}) }}" class="athlete-row {{ item.colorClass }}">
                    <div class="athlete-row-left">
                        <div class="athlete-row-dot"></div>
                        <div class="athlete-row-name">{{ item.player.name }}</div>
                    </div>
                    <div class="athlete-row-metrics">
                        <div class="athlete-row-metric">
                            <div class="athlete-row-metric-val">
                                {{ item.player.score is not null ? item.player.score ~ '/100' : '-/100' }}
                            </div>
                            <div class="athlete-row-metric-label">Score</div>
                        </div>
                        <svg class="athlete-row-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <polyline points="9 18 15 12 9 6"></polyline>
                        </svg>
                    </div>
                </a>
            {% else %}
                <p>Aucun joueur {% if currentFilter != 'all' %}dans cette zone{% else %}actif ces 30 derniers jours{% endif %}.</p>
            {% endfor %}
        </div>
    </div>
{% endblock %}
