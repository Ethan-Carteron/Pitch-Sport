{% extends '_layouts/in_app.html.twig' %}

{% block title %}Gestionnaire d'équipe - PitchSport{% endblock %}

{% block content %}
    <div class="page active" id="page-team-manager">
        <div class="page-header">
            <h1 class="page-title">Gestionnaire d'équipe</h1>
            <p class="page-subtitle">Gérez les coordonnées de vos joueuses et envoyez-leur le questionnaire via WhatsApp.</p>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert-banner vert">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="card team-card">
            <div class="section-title team-section-header">
                <span>Effectif actif</span>
                <form action="{{ path('app_team_manager_telegram_send') }}" method="POST">
                    <button type="submit" class="btn btn-primary btn-telegram">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                        Tout envoyer via Telegram
                    </button>
                </form>
            </div>
            
            <div class="team-list">
                {% for player in activePlayers %}
                    {% set questionnaireUrl = url('app_questionnaire_wellness', {uid: player.uid}) %}
                    
                    <div class="athlete-row vert athlete-row-manage">
                        <div class="athlete-info-col">
                            <div class="athlete-row-dot"></div>
                            <div class="athlete-row-name">{{ player.name }}</div>
                            {% if player.telegramChatId %}
                                <span class="badge badge-telegram">Telegram lié</span>
                            {% else %}
                                <span class="badge badge-pending">En attente de liaison</span>
                            {% endif %}
                        </div>
                        
                        <div class="athlete-actions-col">
                            <form action="{{ path('app_team_manager_phone', {uid: player.uid}) }}" method="POST" class="athlete-phone-form">
                                <input type="tel" name="phone" value="{{ player.phoneNumber }}" class="input input-sm input-phone" placeholder="Ex: +33612345678" aria-label="Numéro de téléphone de {{ player.name }}">
                                <button type="submit" class="btn btn-secondary btn-sm">Enregistrer</button>
                            </form>
                            
                            {% if player.phoneNumber %}
                                {% set waText = "Bonjour " ~ player.name ~ ", voici ton questionnaire de forme du jour : " ~ questionnaireUrl %}
                                <a href="https://wa.me/{{ player.phoneNumber|replace({'+': '', ' ': ''}) }}?text={{ waText|url_encode }}" target="_blank" class="btn btn-primary btn-sm btn-whatsapp">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                                    Envoyer le lien
                                </a>
                            {% else %}
                                <button class="btn btn-secondary btn-sm" disabled title="Renseignez un numéro de téléphone d'abord">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                                    Envoyer le lien
                                </button>
                            {% endif %}
                        </div>
                    </div>
                {% else %}
                    <p>Aucun joueur actif.</p>
                {% endfor %}
            </div>
        </div>
    </div>
{% endblock %}
