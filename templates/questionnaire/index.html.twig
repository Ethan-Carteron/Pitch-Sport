{% extends 'base.html.twig' %}

{% block title %}État de forme - PitchSport{% endblock %}

{% block body %}
<div class="wellness-wrapper">
    <div class="page active" id="page-wellness">
        <div class="page-header wellness-header">
            <h1 class="page-title">Bonjour {{ player.name }}</h1>
            <p class="page-subtitle">Questionnaire du jour — 3 questions, 30 secondes.</p>
        </div>

        <div class="wellness-container">
            {% if submitted %}
                <!-- Confirmation -->
                <div id="wellness-confirm" class="wellness-confirm">
                    <div class="wellness-confirm-icon">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                    </div>
                    <div class="wellness-confirm-text">État de forme enregistré</div>
                    <div class="wellness-confirm-sub">Merci pour tes réponses. Bonne séance !</div>
                </div>
            {% else %}
                <!-- Questions -->
                <form id="wellness-form" method="POST" action="{{ path('app_questionnaire_wellness', {uid: player.uid}) }}">
                    <div class="wellness-questions" id="wellness-questions">

                        <!-- Question Fatigue -->
                        <fieldset class="card wellness-fieldset">
                            <legend class="input-label wellness-input-legend">1. Évalue ta fatigue (1 = Très fatigué, 5 = En pleine forme)</legend>
                            <div class="wellness-options-group">
                                {% for i in 1..5 %}
                                    <label class="wellness-option-label">
                                        <input type="radio" name="fatigue" value="{{ i }}" required class="wellness-radio-input">
                                        <span class="btn btn-secondary btn-full wellness-btn">
                                            {{ i }}
                                        </span>
                                    </label>
                                {% endfor %}
                            </div>
                        </fieldset>

                        <!-- Question Sommeil -->
                        <fieldset class="card wellness-fieldset">
                            <legend class="input-label wellness-input-legend">2. Qualité du sommeil (1 = Très mauvaise, 5 = Excellente)</legend>
                            <div class="wellness-options-group">
                                {% for i in 1..5 %}
                                    <label class="wellness-option-label">
                                        <input type="radio" name="sleep" value="{{ i }}" required class="wellness-radio-input">
                                        <span class="btn btn-secondary btn-full wellness-btn">
                                            {{ i }}
                                        </span>
                                    </label>
                                {% endfor %}
                            </div>
                        </fieldset>

                        <!-- Question Stress -->
                        <fieldset class="card wellness-fieldset">
                            <legend class="input-label wellness-input-legend">3. Niveau de stress (1 = Très stressé, 5 = Très détendu)</legend>
                            <div class="wellness-options-group">
                                {% for i in 1..5 %}
                                    <label class="wellness-option-label">
                                        <input type="radio" name="stress" value="{{ i }}" required class="wellness-radio-input">
                                        <span class="btn btn-secondary btn-full wellness-btn">
                                            {{ i }}
                                        </span>
                                    </label>
                                {% endfor %}
                            </div>
                        </fieldset>

                    </div>
                    <button type="submit" class="btn btn-primary btn-full wellness-submit">
                        Enregistrer mon état de forme
                    </button>
                </form>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
