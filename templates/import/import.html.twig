{% extends '_layouts/in_app.html.twig' %}

{% block title %}import - PitchSport{% endblock %}

{% block content %}
    <div class="page" id="page-import">
        <form action="{{ path('app_import') }}" method="post" enctype="multipart/form-data">
            <div class="page-header">
                <h1 class="page-title">Import GPS</h1>
                <p class="page-subtitle">Importez les données de vos séances directement depuis vos fichiers.</p>
            </div>

            <div class="grid-2" style="margin-bottom: var(--s6)">
                <div class="input-group">
                    <label class="input-label">Matériel GPS</label>
                    <select class="input" id="gps-provider">
                        <option value="">Sélectionnez votre matériel</option>
                        <option value="catapult">Catapult</option>
                        <option value="statsports">STATSports</option>
                        <option value="gpssports">GPSports</option>
                        <option value="polar">Polar Team Pro</option>
                        <option value="autre">Autre (mapping manuel)</option>
                    </select>
                </div>
                <div class="input-group">
                    <label class="input-label">Type de séance</label>
                    <select class="input">
                        <option value="training">Entraînement</option>
                        <option value="match">Match</option>
                    </select>
                </div>
            </div>

            <div class="import-dropzone" id="import-dropzone">
                <div class="import-dropzone-inner" id="import-dropzone-inner">
                    <div class="import-icon">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    </div>
                    <div class="import-text">Glissez votre fichier CSV ici</div>
                    <div class="import-sub">ou</div>
                    <label class="btn btn-secondary" style="cursor:pointer">
                        Parcourir les fichiers
                    </label>
                    <input type="file" name="csv" id="csv-file" accept=".csv" required style="display:block; margin-top: var(--s2);">
                    <div class="import-formats">CSV · XLSX · Compatible Catapult, STATSports, GPSports</div>
                    <div style="margin-top: var(--s5); text-align: center;">
                        <button type="submit" class="btn btn-primary">
                                Lancer l'importation
                         </button>
                    </div>
                </div>
            </div>

            <!-- État : fichier sélectionné -->
            <div class="import-preview" id="import-preview" style="display:none">
                <div class="card" style="margin-top: var(--s5)">
                    <div class="import-file-info" id="import-file-info"></div>
                    <div class="divider"></div>
                    <div class="import-mapping" id="import-mapping">
                        <div class="section-title" style="margin-bottom: var(--s4)">Correspondance des colonnes</div>
                        <div class="mapping-grid" id="mapping-grid"></div>
                    </div>
                    <div style="margin-top: var(--s5); display:flex; gap: var(--s3); justify-content: flex-end">
                        <button class="btn btn-secondary">Annuler</button>
                        <button class="btn btn-primary">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                            Confirmer l'import
                        </button>
                    </div>
                </div>
            </div>

            <!-- Historique imports -->
            <div style="margin-top: var(--s7)">
                <div class="section-title" style="margin-bottom: var(--s4)">Imports récents</div>
                <div id="import-history"></div>
            </div>
        </form>
    </div>
{% endblock %}
