{% extends '_layouts/in_app.html.twig' %}

{% block title %}import - PitchSport{% endblock %}

{% block content %}
    <div class="page" id="page-import">
        <div class="page-header">
            <h1 class="page-title">Import GPS</h1>
            <p class="page-subtitle">Importez les données de vos séances directement depuis vos fichiers.</p>
        </div>

        <form action="{{ path('app_import') }}" method="post" enctype="multipart/form-data" id="import-form">
            <div class="grid-2 import-filters">
                <div class="input-group">
                    <label class="input-label" for="gps-provider">Matériel GPS</label>
                    <select class="input" id="gps-provider" name="gps_provider">
                        <option value="">Sélectionnez votre matériel</option>
                        <option value="catapult">Catapult</option>
                        <option value="statsports">STATSports</option>
                        <option value="gpssports">GPSports</option>
                        <option value="polar">Polar Team Pro</option>
                        <option value="autre">Autre (mapping manuel)</option>
                    </select>
                </div>
                <div class="input-group">
                    <label class="input-label" for="session-type">Type de séance</label>
                    <select class="input" id="session-type" name="session_type">
                        <option value="training">Entraînement</option>
                        <option value="match">Match</option>
                    </select>
                </div>
            </div>

            {# ─── Dropzone : état initial (aucun fichier) ─── #}
            <div class="import-dropzone" id="import-dropzone">
                <div class="import-dropzone-inner" id="import-dropzone-inner">
                    <div class="import-icon">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    </div>
                    <div class="import-text">Glissez votre fichier CSV ici</div>
                    <div class="import-sub">ou</div>
                    <label class="btn btn-secondary import-dropzone-label" for="csv-file">
                        Parcourir les fichiers
                    </label>
                    <input type="file" name="csv" id="csv-file" accept=".csv" required class="sr-only">
                    <div class="import-formats">CSV · Compatible Catapult, STATSports, GPSports</div>
                </div>
            </div>

            {# ─── Dropzone : état fichier sélectionné ─── #}
            <div class="import-preview is-hidden" id="import-preview">
                <div class="card">
                    <div class="import-file-info" id="import-file-info">
                        <div class="import-file-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        </div>
                        <div>
                            <div class="import-file-name" id="import-file-name"></div>
                            <div class="import-file-size" id="import-file-size"></div>
                        </div>
                        <button type="button" class="btn btn-ghost import-file-remove" id="import-file-remove" title="Retirer le fichier">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                    </div>
                </div>
            </div>

            {# ─── Actions ─── #}
            <div class="import-actions is-hidden" id="import-actions">
                <button type="submit" class="btn btn-primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    Lancer l'importation
                </button>
            </div>
        </form>

        {# ─── Historique imports ─── #}
        <div class="import-history-section">
            <div class="section-title">Imports récents</div>
            <div id="import-history">
                <p class="text-sub">Aucun import récent.</p>
            </div>
        </div>
    </div>
{% endblock %}

{% block page_scripts %}
<script src="{{ asset('js/import.js') }}"></script>
{% endblock %}
